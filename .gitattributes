# ---------- Default text files ----------
* text=auto eol=lf

# ---------- Source code ----------
*.js     text eol=lf
*.ts     text eol=lf
*.vue    text eol=lf
*.json   text eol=lf
*.yaml   text eol=lf
*.yml    text eol=lf
*.css    text eol=lf
*.scss   text eol=lf
*.html   text eol=lf

# ---------- Markdown / documentation ----------
*.md     text eol=lf

# ---------- Shell scripts ----------
*.sh     text eol=lf

# ---------- Windows batch scripts ----------
*.bat    text eol=crlf

# ---------- Ignore generated / build files ----------
.nuxt/*      -text
dist/*       -text
.output/*    -text
node_modules/* -text
